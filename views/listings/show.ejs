<% layout("/layouts/boilerplate") %>
<div class="row mt-3">  
<body>
  
    <div class="col-8 offset-2">  
    <h3 class="mb-0"><%= listing.title %> </h3>
    </div>
    <div class="col-6 offset-2">
    <div class="card mt-2 listing-card">
      <img src="<%= listing.image.url %>" class="card-img-top show-image" alt="listing-image">
      <div class="card-body mt-1">
        <p class="card-text">
         
         <%= listing.description %> <br>
         &#36;<%=listing.price.toLocaleString("en-US") %><br>
         <%= listing.location %><br>
         <%= listing.country %><br>
        </p>
      </div>
    </div>
    </div>
<!-- 
    <ul>
      <li><%= listing.title %></li>
      <li><%= listing.description %></li>
      <li>&#36;<%=listing.price.toLocaleString("en-US") %></li>
      <li><%= listing.location %></li>
      <li><%= listing.country %></li>
    </ul>
    <br /> -->
    
  </body>
  <div class="btns mt-2">
    <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark add-btn col-1 offset-2">Edit</a>
  
    <form method="POST" action="/listings/<%=listing._id%>?_method=DELETE" >
      <button class="btn btn-dark add-btn offset-4">Delete</button>
    </form>
    </div>

    <div class="col-8 offset-2 mb-3">
      <hr>
      <h4>Leave a review</h4>
      <form action="/listings/<%= listing.id %>/reviews" method="POST" novalidate class="needs-validation">
        <div class="mb-3 mt-3">
          <label for="rating" class="form-label">Rating</label>
          <input type="range" min="1" max="5" id="rating" name="review[rating]" class="form-range" >
        </div>
        <div class="mb-3 mt-3">
          <label for="comment" class="form-label">Comment</label>
          <textarea name="review[comment]" id="comment" cols="30" rows="5" class="form-control" required></textarea>
          <div class="invalid-feedback">please add some comment for review</div>
        </div>
        <button class="btn btn-outline-dark">Submit</button>
      </form>
      <hr>
      <!-- <h4>All Reviews</h4> -->
      <p><b>All Reviews</b></p>
      <!-- <ul>
      <% for(review of listing.reviews) {%>
      <li>  <%= review.comment %> - <%= review.rating %> stars</li>
      <%}%>
      </ul> -->
      <div class="row">
       <% for(review of listing.reviews) {%>
      <!-- <li>  <%= review.comment %> - <%= review.rating %> stars</li> -->
       <div class="card col-5 ms-3 mb-3">
          <div class="card-body">
           <h5 class="card-title">Hamza</h5>
           <p class="card-text"><%= review.comment%></p>
           <p class="card-text"><%= review.rating%> stars</p>
           <form class="mb-3" method="post" action="/listings/<%=listing._id%>/reviews/<%=review._id%>?_method=DELETE">
            <button class="btn btn-sm btn-dark">Delete</button>
           </form>
           </div>
       </div>
      <%}%>
      </div>
    </div>
</div>
